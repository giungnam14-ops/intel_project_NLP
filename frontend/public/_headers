# Cloudflare Pages cache rules.
# Goal: users always get the newest deploy immediately, while fingerprinted
# assets stay cached for speed.

# HTML entry point + PWA manifest must always be revalidated so a new deploy
# (which references new hashed asset filenames) is picked up on the next visit.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

# Vite-fingerprinted assets are content-hashed, so they never change in place.
# Cache them hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
